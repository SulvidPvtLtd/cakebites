{
  "expo": {
    "name": "Jay Cakes",
    "slug": "jay-cakes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "jaycakes",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#7DCD5D",
      "dark": {
        "image": "./assets/images/splash-icon-dark.png",
        "backgroundColor": "#7DCD5D"
      },
      "imageWidth": 1024
    },
    "ios": {
      "bundleIdentifier": "za.co.jaycakes",
      "supportsTablet": true
    },
    "android": {
      "package": "za.co.jaycakes",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#7DCD5D"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": []
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "expo-system-ui"
    ],
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "97d2c2bd-4083-4d0b-83ce-3855590c27a8"
      }
    },
    "owner": "sulvid"
  }
}
